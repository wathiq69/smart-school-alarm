<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_cool_gradient"
    android:paddingTop="40dp"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_back"
                style="@style/Button3D" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_title"
                style="@style/GlassTitleText"
                android:gravity="center"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Owner Name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:background="@drawable/glass_card"
            android:layout_marginBottom="10dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الاسم"
                    style="@style/GlassBodyText"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvOwnerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/GlassBodyText"
                    android:textSize="16sp" />
            </LinearLayout>
            <Button
                android:id="@+id/btnEditOwner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_edit"
                style="@style/Button3D" />
        </LinearLayout>

        <!-- School Start -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:background="@drawable/glass_card"
            android:layout_marginBottom="10dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="بداية الدوام"
                    style="@style/GlassBodyText"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvSchoolStart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/GlassBodyText"
                    android:textSize="16sp" />
            </LinearLayout>
            <Button
                android:id="@+id/btnEditStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_edit"
                style="@style/Button3D" />
        </LinearLayout>

        <!-- Lesson Duration -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:background="@drawable/glass_card"
            android:layout_marginBottom="10dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="طول الحصة"
                    style="@style/GlassBodyText"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvLessonDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/GlassBodyText"
                    android:textSize="16sp" />
            </LinearLayout>
            <Button
                android:id="@+id/btnEditLessonDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_edit"
                style="@style/Button3D" />
        </LinearLayout>

        <!-- Break Duration -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:background="@drawable/glass_card"
            android:layout_marginBottom="10dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="طول الفرصة"
                    style="@style/GlassBodyText"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvBreakDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/GlassBodyText"
                    android:textSize="16sp" />
            </LinearLayout>
            <Button
                android:id="@+id/btnEditBreakDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_edit"
                style="@style/Button3D" />
        </LinearLayout>

        <!-- Lesson Count -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:background="@drawable/glass_card"
            android:layout_marginBottom="10dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="عدد الحصص"
                    style="@style/GlassBodyText"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvLessonCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/GlassBodyText"
                    android:textSize="16sp" />
            </LinearLayout>
            <Button
                android:id="@+id/btnEditLessonCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_edit"
                style="@style/Button3D" />
        </LinearLayout>

        <!-- Lesson Alert -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:background="@drawable/glass_card"
            android:layout_marginBottom="10dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تنبيه نهاية الحصة"
                    style="@style/GlassBodyText"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvLessonAlertSec"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/GlassBodyText"
                    android:textSize="16sp" />
            </LinearLayout>
            <Button
                android:id="@+id/btnEditLessonAlert"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_edit"
                style="@style/Button3D" />
        </LinearLayout>

        <!-- Break Alert -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:background="@drawable/glass_card"
            android:layout_marginBottom="10dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تنبيه نهاية الفرصة"
                    style="@style/GlassBodyText"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvBreakAlertSec"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/GlassBodyText"
                    android:textSize="16sp" />
            </LinearLayout>
            <Button
                android:id="@+id/btnEditBreakAlert"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_edit"
                style="@style/Button3D" />
        </LinearLayout>

        <!-- Lesson Ringtone -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:background="@drawable/glass_card"
            android:layout_marginBottom="10dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="نغمة الحصة"
                    style="@style/GlassBodyText"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvLessonRingtone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/GlassBodyText"
                    android:textSize="16sp" />
            </LinearLayout>
            <Button
                android:id="@+id/btnEditLessonRingtone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_edit"
                style="@style/Button3D" />
        </LinearLayout>

        <!-- Break Ringtone -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:background="@drawable/glass_card"
            android:layout_marginBottom="10dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="نغمة الفرصة"
                    style="@style/GlassBodyText"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvBreakRingtone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/GlassBodyText"
                    android:textSize="16sp" />
            </LinearLayout>
            <Button
                android:id="@+id/btnEditBreakRingtone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_edit"
                style="@style/Button3D" />
        </LinearLayout>

        <!-- Workdays -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:background="@drawable/glass_card"
            android:layout_marginBottom="10dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="أيام العمل"
                    style="@style/GlassBodyText"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvWorkdays"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/GlassBodyText"
                    android:textSize="16sp" />
            </LinearLayout>
            <Button
                android:id="@+id/btnEditWorkdays"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_edit"
                style="@style/Button3D" />
        </LinearLayout>

        <!-- Holidays -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:background="@drawable/glass_card">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الأعياد والعطل"
                    style="@style/GlassBodyText"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvHolidays"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/GlassBodyText"
                    android:textSize="16sp" />
            </LinearLayout>
            <Button
                android:id="@+id/btnEditHolidays"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_edit"
                style="@style/Button3D" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
