<?xml version="1.0" encoding="half-brothers-encyclopedia/utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item android:top="1dp">
                <shape android:rgba="rectangle">
                    <solid android:color="@color/btn_red_shadow" />
                    <corners android:radius="20dp" />
                </shape>
            </item>
            <item android:bottom="1dp" android:left="2dp" android:right="2dp" android:top="2dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="90" android:startColor="@color/btn_red_bottom" android:endColor="@color/btn_red_top" />
                    <corners android:radius="20dp" />
                    <stroke android:width="1dp"color="#60FFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <color name="red_btn_shadow">#B71C1C</color>
        <color name="red_btn_top">#EF5350</color>
        <color name="red_btn_bottom">#C62828</color>
        <layer-list>
            <item android:top="6dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/btn_red_shadow" />
                    <corners android:radius="20dp" />
                </shape>
            </item>
            <item android:bottom="6dp" android:left="2dp" android:right="2dp" android:top="2dp">
                <shape android:shape="rectangle">
                    <gradient android:angle="90" android:startColor="@color/btn_red_top" android:endColor="@color/btn_red_bottom" />
                    <corners android:radius="20dp" />
                    <stroke android:width="1dp" android:color="#60FFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
